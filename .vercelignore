# Desktop client lives in the same repo but is NOT a Vercel artifact.
# Without this, vercel deploy tries to upload the Rust target/ (1.5 GB),
# rate-limiting the free-tier upload quota after one push.
vaani-desktop/

# Chrome extension — static files, not deployed through Vercel either.
vaani-ext/

# Build artefacts we don't need the server to rebuild with.
.next/cache/
node_modules/.cache/
*.dmg
*.log
